# Copy to .env.local for local dev. Production uses /etc/default/rcl-watch.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Optional: override shared auth cookie domain (default .retrocyclesleague.com on prod hosts)
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.retrocyclesleague.com
